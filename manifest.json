{
	"manifest_version": 3,
	"name": "TabNest",
	"description": "Nest and group tabs by category.",
	"version": "1.0",
	"permissions": ["tabs", "tabGroups", "storage"],
	"background": {
		"service_worker": "background.js"
	},
	"icons": {
		"16": "logo/TabNest-logo.png",
		"48": "logo/TabNest-logo.png",
		"128": "logo/TabNest-logo.png"
	},
	"action": {
		"default_icon": {
			"16": "logo/TabNest-logo.png",
			"48": "logo/TabNest-logo.png"
		},
		"default_popup": "popup.html"
	}
}
